#!/bin/sh

echo -e "\ue00d"

bg="$(xrdb -query | awk '/\*\.background:/ {print $2}')"
fg="$(xrdb -query | awk '/\*\.foreground:/ {print $2}')"
sb="$(xrdb -query | awk '/\*\.color4:/ {print $2}')"
sf="$(xrdb -query | awk '/\*\.foreground:/ {print $2}')"

case $BLOCK_BUTTON in
    1)
        choice=$(printf "Lock\nReboot\nShutdown\n" | dmenu -i -nb "$bg" -nf "$fg" -sb "$sb" -sf "$sf" -p "Power:" -l 3)

        case "$choice" in
            "Lock")
                echo "Lock"
                ;;
            "Reboot")
                reboot
                ;;
            "Shutdown")
                poweroff
                ;;
        esac
        ;;
esac
