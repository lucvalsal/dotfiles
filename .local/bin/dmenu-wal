#!/bin/sh

bg=$(xrdb -query | awk '/^\*\.background:/ {print $2}' | xargs)
fg=$(xrdb -query | awk '/^\*\.foreground:/ {print $2}' | xargs)
sb=$(xrdb -query | awk '/^\*\.color4:/ {print $2}' | xargs)
sf=$(xrdb -query | awk '/^\*\.foreground:/ {print $2}' | xargs)


dmenu_run -i -nb "$bg" -nf "$fg" -sb "$sb" -sf "$sf"

